---
import Logo from "./Logo.astro";
import Button from "./Button.astro";

const appUrl = "http://app.medienkundig.local";
const loginUrl = `${appUrl}?auth=login`;
const onboardingUrl = `${appUrl}?onboarding=1`;

const navLinks = [
  { label: "Lernen", href: "/lernen" },
  { label: "Glossar", href: "/glossar" },
  { label: "Quellen", href: "/quellen" },
  { label: "App", href: appUrl },
  { label: "Über uns", href: "/ueber-uns" },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <Logo />

    <nav class="site-nav" aria-label="Hauptnavigation">
      <ul class="site-nav__list" role="list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="site-nav__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href={loginUrl} class="site-header__login">Einloggen</a>
      <Button href={onboardingUrl} variant="primary" size="sm">Loslegen</Button>
    </div>

    <button
      class="site-header__burger"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Menü öffnen"
    >
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
      <span class="burger-bar"></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobilnavigation">
      <ul class="mobile-menu__list" role="list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="mobile-menu__link">{link.label}</a>
          </li>
        ))}
        <li class="mobile-menu__divider" aria-hidden="true"></li>
        <li><a href={loginUrl} class="mobile-menu__link">Einloggen</a></li>
        <li>
          <Button href={onboardingUrl} variant="primary" size="md" class="mobile-menu__cta">
            Loslegen
          </Button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      menu.setAttribute("aria-hidden", String(isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Menü öffnen" : "Menü schließen");
    });
  }
</script>
