---
import Button from "./Button.astro";

const onboardingUrl = "http://app.medienkundig.local?onboarding=1";
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__inner">

    <!-- Left: content -->
    <div class="hero__content">
      <span class="hero__eyebrow">Medienkompetenz für jeden</span>

      <h1 id="hero-heading" class="hero__heading">
        Verstehen. Erkennen.<br />
        <span class="hero__heading--accent">Sicher Bleiben.</span>
      </h1>

      <p class="hero__body">
        Interaktive Lernpfade die dich für den digitalen Alltag stark machen.
      </p>

      <div class="hero__actions">
        <Button href={onboardingUrl} variant="primary" size="lg">Zum Selbsttest</Button>
        <Button href={onboardingUrl} variant="secondary" size="lg">Erste Schritte</Button>
      </div>

      <div class="hero__rating" aria-label="4,9 von 5 Sternen – Von über 12.000 Lernenden empfohlen">
        <div class="hero__avatars" aria-hidden="true">
          <span class="hero__avatar hero__avatar--1"></span>
          <span class="hero__avatar hero__avatar--2"></span>
          <span class="hero__avatar hero__avatar--3"></span>
        </div>
        <div class="hero__rating-text">
          <span class="hero__stars" aria-hidden="true">★★★★★</span>
          <span class="hero__rating-score">4,9/5</span>
          <span class="hero__rating-label">Von über 12.000 Lernenden empfohlen</span>
        </div>
      </div>
    </div>

    <!-- Right: visual -->
    <div class="hero__visual" aria-hidden="true">
      <!-- decorative rings -->
      <div class="hero__ring hero__ring--outer"></div>
      <div class="hero__ring hero__ring--inner"></div>

      <!-- mascot -->
      <img
        src="/assets/tinty.png"
        alt=""
        class="hero__mascot"
        width="380"
        height="380"
        loading="eager"
      />

      <!-- chips – absolutely positioned around the ring -->
      <span class="hero__chip hero__chip--top hero__chip--pink" data-glossar="phishing" role="button" tabindex="0" title="Phishing nachschlagen">
        <span class="hero__chip-dot"></span>Phishing
      </span>
      <span class="hero__chip hero__chip--left-top hero__chip--lavender" data-glossar="deepfake" role="button" tabindex="0" title="Deepfake nachschlagen">
        <span class="hero__chip-dot"></span>Deepfake
      </span>
      <span class="hero__chip hero__chip--left-mid hero__chip--teal" data-glossar="fake-news" role="button" tabindex="0" title="Fake News nachschlagen">
        <span class="hero__chip-dot"></span>Fake News
      </span>
      <span class="hero__chip hero__chip--left-bottom hero__chip--purple" data-glossar="ki" role="button" tabindex="0" title="KI nachschlagen">
        <span class="hero__chip-dot"></span>KI & Co
      </span>
      <span class="hero__chip hero__chip--right-bottom hero__chip--amber" data-glossar="dsgvo" role="button" tabindex="0" title="Datenschutz nachschlagen">
        <span class="hero__chip-dot"></span>Datenschutz
      </span>
    </div>

  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <svg class="hero__scroll-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M6 9l6 6 6-6" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- wave transition to white sections below -->
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,120 C300,120 600,0 1200,0 L1440,0 L1440,120 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

