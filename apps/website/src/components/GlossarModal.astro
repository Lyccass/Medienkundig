---
import { glossarTerms } from "@medienkundig/ui";
---

<div class="gm" id="glossar-modal" role="dialog" aria-modal="true" aria-labelledby="gm-term" hidden>
  <div class="gm__backdrop"></div>

  <div class="gm__sheet">
    <div class="gm__close-row">
      <button class="gm__close" aria-label="Schließen" type="button">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="gm__body">
      <p class="gm__category" id="gm-category"></p>
      <h2 class="gm__term" id="gm-term"></h2>
      <p class="gm__short" id="gm-short"></p>
      <div class="gm__divider"></div>
      <p class="gm__full" id="gm-full"></p>
      <div class="gm__example" id="gm-example" hidden>
        <span class="gm__example-label">Beispiel</span>
        <p class="gm__example-text" id="gm-example-text"></p>
      </div>
      <div class="gm__media" id="gm-media" hidden></div>
      <div class="gm__related" id="gm-related"></div>
    </div>

    <div class="gm__footer">
      <a href="/glossar" class="gm__link">Alle Begriffe im Glossar →</a>
    </div>
  </div>
</div>

<script type="application/json" id="glossar-term-data" is:inline set:html={JSON.stringify(glossarTerms)}></script>

<script>
  type Term = {
    id: string; term: string; category: string;
    short: string; full: string; related: string[];
    example?: string;
    source?: { label: string; url: string };
    media?: { type: "image" | "youtube"; src: string; caption?: string };
  };

  const terms: Term[] = JSON.parse(
    document.getElementById("glossar-term-data")!.textContent!
  );

	  const modal    = document.getElementById("glossar-modal") as HTMLElement;
	  const backdrop = modal.querySelector<HTMLElement>(".gm__backdrop")!;
	  const closeBtn = modal.querySelector<HTMLButtonElement>(".gm__close")!;

	  function getSafeExternalUrl(rawUrl: string) {
	    try {
	      const url = new URL(rawUrl, window.location.origin);
	      return url.protocol === "https:" || url.protocol === "http:" ? url.href : null;
	    } catch {
	      return null;
	    }
	  }

	  function createExternalIcon() {
	    const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
	    svg.setAttribute("width", "12");
	    svg.setAttribute("height", "12");
	    svg.setAttribute("viewBox", "0 0 12 12");
	    svg.setAttribute("fill", "none");

	    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
	    path.setAttribute("d", "M2 10L10 2M10 2H5M10 2v5");
	    path.setAttribute("stroke", "currentColor");
	    path.setAttribute("stroke-width", "1.5");
	    path.setAttribute("stroke-linecap", "round");
	    path.setAttribute("stroke-linejoin", "round");
	    svg.append(path);

	    return svg;
	  }

  function open(id: string) {
    const t = terms.find((t) => t.id === id);
    if (!t) return;

    (modal.querySelector("#gm-category") as HTMLElement).textContent = t.category;
    (modal.querySelector("#gm-term") as HTMLElement).textContent     = t.term;
    (modal.querySelector("#gm-short") as HTMLElement).textContent    = t.short;
    (modal.querySelector("#gm-full") as HTMLElement).textContent     = t.full;

    // Example
    const exEl   = modal.querySelector("#gm-example") as HTMLElement;
    const exText = modal.querySelector("#gm-example-text") as HTMLElement;
    if (t.example) {
      exText.textContent = t.example;
      exEl.hidden = false;
    } else {
      exEl.hidden = true;
    }

	    // Media
	    const mediaEl = modal.querySelector("#gm-media") as HTMLElement;
	    mediaEl.replaceChildren();
	    if (t.media) {
	      if (t.media.type === "youtube") {
	        const iframe = document.createElement("iframe");
	        iframe.src = `https://www.youtube-nocookie.com/embed/${encodeURIComponent(t.media.src)}`;
	        iframe.allowFullscreen = true;
	        iframe.loading = "lazy";
	        iframe.title = t.term;
	        mediaEl.append(iframe);
	      } else {
	        const image = document.createElement("img");
	        image.src = t.media.src;
	        image.alt = t.term;
	        image.loading = "lazy";
	        mediaEl.append(image);
	      }
	      if (t.media.caption) {
	        const caption = document.createElement("p");
	        caption.className = "gm__media-caption";
	        caption.textContent = t.media.caption;
	        mediaEl.append(caption);
	      }
	      mediaEl.hidden = false;
	    } else {
	      mediaEl.hidden = true;
	    }

	    // Related terms
	    const relEl = modal.querySelector("#gm-related") as HTMLElement;
	    relEl.replaceChildren();
	    if (t.related.length > 0) {
	      const related = t.related
	        .map((rid) => terms.find((x) => x.id === rid))
	        .filter(Boolean) as Term[];
	      const label = document.createElement("span");
	      label.className = "gm__related-label";
	      label.textContent = "Verwandt";
	      relEl.append(label);
	      related.forEach((r) => {
	        const button = document.createElement("button");
	        button.className = "gm__related-chip";
	        button.dataset.glossar = r.id;
	        button.type = "button";
	        button.textContent = r.term;
	        relEl.append(button);
	      });
	    }

	    // Source in footer
	    const footerEl = modal.querySelector(".gm__footer") as HTMLElement;
	    const srcEl    = footerEl.querySelector(".gm__source") as HTMLElement | null;
	    const safeSourceUrl = t.source ? getSafeExternalUrl(t.source.url) : null;
	    if (t.source && safeSourceUrl) {
	      const sourceLink = document.createElement("a");
	      sourceLink.className = "gm__source";
	      sourceLink.href = safeSourceUrl;
	      sourceLink.target = "_blank";
	      sourceLink.rel = "noopener";
	      sourceLink.title = "Quelle öffnen";
	      sourceLink.append(createExternalIcon(), document.createTextNode(t.source.label));
	      if (srcEl) srcEl.replaceWith(sourceLink);
	      else footerEl.prepend(sourceLink);
	    } else if (srcEl) {
	      srcEl.remove();
	    }

    modal.hidden = false;
    document.body.classList.add("is-overlay-open");
    closeBtn.focus();
  }

  function close() {
    modal.hidden = true;
    document.body.classList.remove("is-overlay-open");
  }

  document.addEventListener("click", (e) => {
    const el = (e.target as HTMLElement).closest<HTMLElement>("[data-glossar]");
    if (el?.dataset.glossar) open(el.dataset.glossar);
  });

  backdrop.addEventListener("click", close);
  closeBtn.addEventListener("click", close);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.hidden) close();
  });

	  window.__glossar = { open, close };
</script>
