---
interface Props {
  size?: "sm" | "md" | "lg";
  href?: string;
}
const { size = "md", href = "/" } = Astro.props;
---

<a href={href} class={`logo logo--${size}`} aria-label="medienkundig – Startseite">
  {size === "sm" ? (
    <img src="/logo_small.png" alt="medienkundig" class="logo__img logo__img--small" />
  ) : (
    <img src="/assets/Logo.png" alt="medienkundig" class="logo__img" />
  )}
</a>

