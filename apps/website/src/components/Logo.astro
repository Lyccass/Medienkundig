---
interface Props {
  size?: "sm" | "md" | "lg";
  href?: string;
}
const { size = "md", href = "/" } = Astro.props;
---

<a href={href} class={`logo logo--${size}`} aria-label="medienkundig – Startseite">
  {size === "sm" ? (
    <img src="/logo_small.png" alt="medienkundig" class="logo__img logo__img--small" />
  ) : (
    <img src="/assets/Logo.png" alt="medienkundig" class="logo__img" />
  )}
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo__img {
    height: 36px;
    width: auto;
    display: block;
  }

  .logo__img--small {
    height: 28px;
  }

  .logo--lg .logo__img {
    height: 44px;
  }
</style>
