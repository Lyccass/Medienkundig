---
const cards = [
  {
    tag: "Phishing & Fake-Mails",
    question: "Ist diese E-Mail echt oder ein Betrugsversuch?",
    hint: `Schau dir Absender-<span data-glossar="domain" class="glossar-inline">Domain</span> und Inhalt genau an.`,
    img: "/assets/Screenshot 2026-06-02 at 10.31.20.png",
    imgAlt: "Spam-E-Mail Beispiel",
    opts: [
      { label: "Sieht echt aus", correct: false },
      { label: "Betrugsversuch", correct: true },
    ],
    explanation: "Die Domain kanairpw.com hat keinen Bezug zum angeblichen Absender – der E-Mail-Client markiert sie bereits als Junk. Echte Unternehmen versenden keine unaufgeforderten Angebote über obskure Drittdienste.",
  },
  {
    tag: "Fake News & Deepfakes",
    question: "Glaubwürdige Meldung oder Falschinformation?",
    hint: "Achte auf die Quelle und den journalistischen Kontext.",
    img: "/assets/Screenshot 2026-06-02 at 10.36.39.png",
    imgAlt: "Volksverpetzer Faktencheck-Artikel",
    opts: [
      { label: "Glaubwürdig", correct: true },
      { label: "Wahrscheinlich falsch", correct: false },
    ],
    explanation: "Volksverpetzer ist ein etabliertes Faktencheck-Portal. Das Gericht hat ihre Berichterstattung bestätigt – ein klares Zeichen für seriösen Journalismus. Nicht jeder kritische Artikel ist automatisch Fake News.",
  },
  {
    tag: "Online-Sicherheit",
    question: "Seriöser Shop oder eine Falle?",
    hint: `Prüfe <span data-glossar="url" class="glossar-inline">URL</span>, Verkäufer, Preis und Zahlungsoptionen.`,
    img: "/assets/Screenshot 2026-06-02 at 10.32.21.png",
    imgAlt: "Amazon iPhone 16e Produktseite",
    opts: [
      { label: "Seriöser Shop", correct: true },
      { label: "Könnte Falle sein", correct: false },
    ],
    explanation: "Realistischer Preis · HTTPS-Verbindung · bekannte Domain amazon.de · Amazon als Verkäufer · Prime-Lieferung. Alle Vertrauenssignale stimmen.",
  },
];
---

<section class="section why" aria-labelledby="why-heading">
  <div class="container">

    <div class="why__header">
      <span class="label-eyebrow">Was Sie lernen</span>
      <h2 id="why-heading" class="why__title">Erkennen Sie den Unterschied?</h2>
      <p class="why__intro">
        Genau so lernen Sie bei medienkundig – anhand echter Beispiele, die Sie selbst einschätzen.
      </p>
    </div>

    <!-- Quiz frame -->
    <div class="quiz" id="why-quiz">

      <!-- Top bar: back + progress -->
      <div class="quiz__topbar">
        <button class="quiz__back" id="quiz-back" type="button" aria-label="Vorherige Frage" hidden>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="quiz__progress" role="progressbar" aria-valuemin="0" aria-valuemax={cards.length} aria-valuenow="1">
          {cards.map((_, i) => (
            <div class={`quiz__seg ${i === 0 ? "quiz__seg--active" : ""}`} data-seg={i}></div>
          ))}
        </div>
      </div>

      <!-- Steps -->
      {cards.map((card, i) => (
        <div class="quiz__step" data-step={i} aria-hidden={i !== 0 ? "true" : "false"} style={i !== 0 ? "display:none" : ""}>
          <div class="quiz__step-meta">
            <span class="quiz__step-count">Aufgabe {i + 1} / {cards.length}</span>
            <span class="quiz__step-tag">{card.tag}</span>
          </div>

          <h3 class="quiz__question">{card.question}</h3>
          <p class="quiz__hint" set:html={card.hint}></p>

          <button
            class="quiz__img-btn"
            data-lightbox={card.img}
            type="button"
            aria-label="Bild vergrößern"
          >
            <img src={card.img} alt={card.imgAlt} class="quiz__img" loading={i === 0 ? "eager" : "lazy"} />
            <span class="quiz__zoom-hint" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4"/>
                <path d="M10 10l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <path d="M6 4v4M4 6h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Vergrößern
            </span>
          </button>

          <div class="quiz__opts" role="group" aria-label="Antwortoptionen">
            {card.opts.map((opt) => (
              <button
                class="quiz__opt"
                data-correct={opt.correct ? "true" : "false"}
                type="button"
              >
                {opt.label}
              </button>
            ))}
          </div>

          <div class="quiz__explanation" aria-live="polite" hidden>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="8" fill="#dcfce7"/>
              <polyline points="5,9 8,12 13,6" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p>{card.explanation}</p>
          </div>
        </div>
      ))}

      <!-- Bottom nav -->
      <div class="quiz__nav">
        <button class="quiz__nav-btn quiz__nav-btn--ghost" id="quiz-prev" type="button" disabled>
          Zurück
        </button>
        <button class="quiz__nav-btn quiz__nav-btn--primary" id="quiz-next" type="button" disabled>
          Weiter
        </button>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Section header ── */
  .why__header {
    text-align: center;
    margin-bottom: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }
  .why__title { font-size: var(--text-4xl); line-height: var(--leading-tight); }
  .why__intro {
    font-size: var(--text-md);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  /* ── Quiz frame ── */
  .quiz {
    max-width: 680px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Top bar */
  .quiz__topbar {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .quiz__back {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.15s, color 0.15s;
  }
  .quiz__back:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .quiz__back[hidden] { display: none; }

  .quiz__progress {
    flex: 1;
    display: flex;
    gap: var(--space-2);
  }

  .quiz__seg {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: var(--color-border);
    transition: background 0.3s ease;
  }
  .quiz__seg--active { background: var(--color-primary); }
  .quiz__seg--done   { background: var(--color-primary); opacity: 0.45; }

  /* Step */
  .quiz__step {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .quiz__step-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .quiz__step-count {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .quiz__step-tag {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-primary);
    background: var(--color-primary-soft);
    padding: 3px 10px;
    border-radius: var(--radius-full);
  }

  .quiz__question {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }

  .quiz__hint {
    font-size: var(--text-base);
    color: var(--color-muted);
    margin: 0;
    margin-top: calc(var(--space-5) * -0.5);
  }


  /* Image */
  .quiz__img-btn {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: zoom-in;
    background: none;
  }

  .quiz__img {
    display: block;
    width: 100%;
    height: 320px;
    object-fit: cover;
    object-position: top;
    transition: transform 0.2s ease;
  }
  .quiz__img-btn:hover .quiz__img { transform: scale(1.02); }

  .quiz__zoom-hint {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    background: rgba(0,0,0,0.55);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    border-radius: var(--radius-full);
    backdrop-filter: blur(4px);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.18s, transform 0.18s;
    pointer-events: none;
  }
  .quiz__img-btn:hover .quiz__zoom-hint { opacity: 1; transform: translateY(0); }

  /* Answer buttons */
  .quiz__opts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .quiz__opt {
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 700;
    color: var(--color-text-soft);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
    line-height: var(--leading-snug);
    text-align: center;
  }
  .quiz__opt:hover:not(:disabled) {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-soft);
    transform: translateY(-1px);
  }
  .quiz__opt:disabled { cursor: default; }
  .quiz__opt[data-result="correct"] {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .quiz__opt[data-result="wrong"] {
    background: #fee2e2;
    border-color: #fca5a5;
    color: #b91c1c;
    opacity: 0.55;
    text-decoration: line-through;
  }

  /* Explanation */
  .quiz__explanation {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-lg);
    animation: fade-up 0.25s ease;
  }
  .quiz__explanation[hidden] { display: none; }
  .quiz__explanation p {
    font-size: var(--text-sm);
    color: #166534;
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Bottom nav */
  .quiz__nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    padding-top: var(--space-2);
  }

  .quiz__nav-btn {
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-lg);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, opacity 0.15s;
  }
  .quiz__nav-btn:disabled { opacity: 0.35; cursor: default; }

  .quiz__nav-btn--ghost {
    border: 1.5px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-soft);
  }
  .quiz__nav-btn--ghost:not(:disabled):hover {
    border-color: var(--color-text-soft);
  }

  .quiz__nav-btn--primary {
    border: 2px solid var(--color-primary);
    background: var(--color-primary);
    color: #fff;
  }
  .quiz__nav-btn--primary:not(:disabled):hover {
    background: #5a2de0;
    border-color: #5a2de0;
  }

  @media (max-width: 600px) {
    .quiz__img { height: 220px; }
    .quiz__opts { grid-template-columns: 1fr; }
  }
</style>

<script>
  const quiz      = document.getElementById("why-quiz")!;
  const steps     = Array.from(quiz.querySelectorAll<HTMLElement>(".quiz__step"));
  const segs      = Array.from(quiz.querySelectorAll<HTMLElement>(".quiz__seg"));
  const backBtn   = quiz.querySelector<HTMLButtonElement>("#quiz-back")!;
  const prevBtn   = quiz.querySelector<HTMLButtonElement>("#quiz-prev")!;
  const nextBtn   = quiz.querySelector<HTMLButtonElement>("#quiz-next")!;

  let current  = 0;
  const answered = new Array(steps.length).fill(false);

  function showStep(idx: number) {
    steps.forEach((s, i) => {
      s.style.display = i === idx ? "" : "none";
      s.setAttribute("aria-hidden", i === idx ? "false" : "true");
    });
    segs.forEach((seg, i) => {
      seg.classList.toggle("quiz__seg--active", i === idx);
      seg.classList.toggle("quiz__seg--done",   i < idx);
    });
    backBtn.hidden   = idx === 0;
    prevBtn.disabled = idx === 0;
    nextBtn.disabled = !answered[idx];

    const isLast = idx === steps.length - 1;
    nextBtn.textContent = isLast
      ? (answered[idx] ? "Fertig ✓" : "Weiter")
      : "Weiter";
    current = idx;
  }

  // Answer buttons
  steps.forEach((step, stepIdx) => {
    step.querySelectorAll<HTMLButtonElement>(".quiz__opt").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (answered[stepIdx]) return;
        answered[stepIdx] = true;

        step.querySelectorAll<HTMLButtonElement>(".quiz__opt").forEach((b) => {
          b.disabled = true;
          b.dataset.result = b.dataset.correct === "true" ? "correct" : "wrong";
        });

        const expl = step.querySelector<HTMLElement>(".quiz__explanation")!;
        expl.hidden = false;

        nextBtn.disabled = false;
        const isLast = stepIdx === steps.length - 1;
        if (isLast) nextBtn.textContent = "Fertig ✓";
      });
    });

    // Lightbox
    step.querySelector<HTMLButtonElement>(".quiz__img-btn")?.addEventListener("click", (e) => {
      const btn = (e.currentTarget as HTMLButtonElement);
      const src = btn.dataset.lightbox!;
      const alt = btn.querySelector("img")?.alt ?? "";
      (window as any).__lightbox?.open(src, alt);
    });
  });

  backBtn.addEventListener("click", () => { if (current > 0) showStep(current - 1); });
  prevBtn.addEventListener("click", () => { if (current > 0) showStep(current - 1); });
  nextBtn.addEventListener("click", () => { if (current < steps.length - 1) showStep(current + 1); });

  showStep(0);
</script>
