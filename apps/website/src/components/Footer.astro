---
import Logo from "./Logo.astro";

const columns = [
  {
    heading: "Lernen",
    links: [
      { label: "Lernpfade", href: "/lernen" },
      { label: "Glossar", href: "/glossar" },
      { label: "Quellen", href: "/quellen" },
    ],
  },
  {
    heading: "Über uns",
    links: [
      { label: "Über das Projekt", href: "/ueber-uns" },
    ],
  },
  {
    heading: "Rechtliches",
    links: [
      { label: "Impressum", href: "/impressum" },
      { label: "Datenschutz", href: "/datenschutz" },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <Logo />
        <p class="site-footer__claim">
          Wir stärken Medienkompetenz –<br />für eine sichere und mündige Gesellschaft.
        </p>
      </div>

      <nav class="site-footer__nav" aria-label="Footer-Navigation">
        {columns.map((col) => (
          <div class="site-footer__col">
            <h3 class="site-footer__col-heading">{col.heading}</h3>
            <ul role="list">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="site-footer__link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copy">
        &copy; {new Date().getFullYear()} medienkundig – Sicher. Stark. Digital.
      </p>
    </div>
  </div>
</footer>

