---
import Button from "./Button.astro";

type ButtonVariant = "primary" | "secondary" | "ghost";
type VisualVariant = "pink" | "mint" | "lavender" | "amber";

interface Step {
  heading: string;
  text: string;
  cta: {
    label: string;
    href: string;
    variant: ButtonVariant;
  };
  visual: VisualVariant;
  mascot: "lean-left" | "lean-right" | "large-left" | "large-right" | "soft-left";
}

const steps: Step[] = [
  {
    heading: "Selbsttest machen",
    text: "Finden Sie in wenigen Minuten heraus, wie gut Sie digitale Bedrohungen schon erkennen – und wo Lernpotenzial steckt.",
    cta: { label: "Einstufung starten", href: "http://app.medienkundig.local", variant: "primary" },
    visual: "pink",
    mascot: "lean-left",
  },
  {
    heading: "Lernpfad entdecken",
    text: "Basierend auf Ihrem Testergebnis erhalten Sie einen persönlichen Lernpfad – abgestimmt auf Ihre Kenntnisse und Ihr Tempo.",
    cta: { label: "App öffnen", href: "http://app.medienkundig.local", variant: "secondary" },
    visual: "mint",
    mascot: "lean-right",
  },
  {
    heading: "Themen verstehen",
    text: "Kurze, interaktive Lektionen erklären Risiken im Alltag – mit echten Beispielen, die Sie sofort einordnen können.",
    cta: { label: "Zum Glossar", href: "/glossar", variant: "secondary" },
    visual: "lavender",
    mascot: "large-left",
  },
  {
    heading: "Wissen festigen",
    text: "Interaktive Übungen und echte Fallbeispiele helfen, das Gelernte zu festigen – jederzeit wiederholbar, in Ihrem Tempo.",
    cta: { label: "Übungen starten", href: "http://app.medienkundig.local", variant: "secondary" },
    visual: "amber",
    mascot: "large-right",
  },
  {
    heading: "Sicher handeln",
    text: "Wenden Sie Ihr Wissen im Alltag an und schützen Sie sich und andere nachhaltig vor Betrug, Fehlinformation und digitalen Fallen.",
    cta: { label: "Jetzt loslegen", href: "http://app.medienkundig.local", variant: "primary" },
    visual: "mint",
    mascot: "soft-left",
  },
];
---

<section class="section learning-steps" aria-labelledby="steps-heading">
  <div class="container">

    <div class="learning-steps__header">
      <span class="label-eyebrow">So einfach geht's</span>
      <h2 id="steps-heading" class="learning-steps__title">In 5 Schritten sicherer im Netz</h2>
    </div>

    {steps.map((step, i) => (
      <div class={`step-row ${i % 2 !== 0 ? "step-row--reversed" : ""}`}>

        <div class="step-row__text">
          <h3 class="step-row__heading">{step.heading}</h3>
          <p class="step-row__body">{step.text}</p>
          <Button href={step.cta.href} variant={step.cta.variant}>{step.cta.label}</Button>
        </div>

        <div class="step-row__visual">
          <div class="step-visual">
            <div class={`step-visual__blob step-visual__blob--${step.visual}`}></div>
            <img
              src="/assets/tinty.png"
              alt=""
              class={`step-visual__mascot step-visual__mascot--${step.mascot}`}
              loading="lazy"
            />
          </div>
        </div>

      </div>
    ))}

  </div>
</section>

