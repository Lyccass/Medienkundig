---
interface Props {
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit";
  class?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  class: className,
} = Astro.props;

const Tag = href ? "a" : "button";
---

{href ? (
  <a href={href} class={`btn btn--${variant} btn--${size} ${className ?? ""}`}>
    <slot />
  </a>
) : (
  <button type={type} class={`btn btn--${variant} btn--${size} ${className ?? ""}`}>
    <slot />
  </button>
)}

