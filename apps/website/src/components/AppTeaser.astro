---
import Button from "./Button.astro";

const onboardingUrl = "http://app.medienkundig.local?onboarding=1";
---

<section class="section app-teaser" aria-labelledby="app-teaser-heading">
  <div class="container">
    <div class="app-teaser__inner">

      <!-- Left: content -->
      <div class="app-teaser__content">
        <span class="label-eyebrow">Immer dabei, immer informiert</span>
        <h2 id="app-teaser-heading" class="app-teaser__title">
          Lernen, wann es passt.
        </h2>
        <p class="app-teaser__text">
          Die medienkundig App begleitet Sie mit kurzen Übungen, Fortschritt und
          Wiederholungen – am Smartphone, Tablet oder Desktop.
        </p>
        <Button href={onboardingUrl} variant="primary" size="lg">
          Zur App
        </Button>
      </div>

      <!-- Right: app mockup image -->
      <div class="app-teaser__visual" aria-hidden="true">
        <img
          src="/assets/app-mockup.png"
          alt=""
          class="app-teaser__mockup"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>

