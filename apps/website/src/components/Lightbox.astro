---

<div class="lightbox" id="global-lightbox" role="dialog" aria-modal="true" aria-label="Bildvorschau" hidden>
  <div class="lightbox__backdrop"></div>
  <button class="lightbox__close" aria-label="Schließen" type="button">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path d="M5 5l10 10M15 5l-10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <div class="lightbox__frame">
    <img class="lightbox__img" src="" alt="" />
  </div>
</div>

<script>
  const lb     = document.getElementById("global-lightbox") as HTMLElement;
  const img    = lb.querySelector<HTMLImageElement>(".lightbox__img")!;
  const close  = lb.querySelector<HTMLButtonElement>(".lightbox__close")!;
  const backdrop = lb.querySelector<HTMLElement>(".lightbox__backdrop")!;

  function open(src: string, alt = "") {
    img.src = src;
    img.alt = alt;
    lb.hidden = false;
    document.body.classList.add("is-overlay-open");
    close.focus();
  }

  function closeLb() {
    lb.hidden = true;
    document.body.classList.remove("is-overlay-open");
    img.src = "";
  }

  close.addEventListener("click", closeLb);
  backdrop.addEventListener("click", closeLb);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !lb.hidden) closeLb();
  });

	  window.__lightbox = { open, close: closeLb };
</script>
