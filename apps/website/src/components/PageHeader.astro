---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<div class="page-head">
  <div class="container page-head__inner">
    <div class="page-head__text">
      {eyebrow && <span class="label-eyebrow">{eyebrow}</span>}
      <h1 class="page-head__title">{title}</h1>
      {subtitle && <p class="page-head__sub">{subtitle}</p>}
    </div>
    <slot />
  </div>
  <div class="page-head__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,80 C360,80 720,0 1440,0 L1440,80 Z" fill="#ffffff"/>
    </svg>
  </div>
</div>

<style>
  .page-head {
    background: var(--color-primary-soft);
    padding-block: var(--space-16) 0;
    position: relative;
  }

  .page-head__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-top: var(--space-10);
  }

  .page-head__text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .page-head__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-text);
    line-height: 1;
    margin-top: var(--space-2);
  }

  .page-head__sub {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-2);
  }

  .page-head__wave {
    line-height: 0;
    margin-top: var(--space-10);
  }

  .page-head__wave svg {
    display: block;
    width: 100%;
    height: 80px;
  }
</style>
