---
interface Props {
  posterSrc?: string;
  videoSrc?: string;
  embedUrl?: string;
}

const {
  posterSrc = "/assets/video-poster-placeholder.svg",
  videoSrc,
  embedUrl,
} = Astro.props;

const expectations = [
  "Wie digitale Risiken im Alltag wirklich aussehen",
  "Wie medienkundig Sie Schritt für Schritt begleitet",
  "Was Sie nach 10 Minuten Lernen bereits erkennen können",
];
---

<section class="section video-intro" id="video-intro" aria-labelledby="video-intro-heading">
  <div class="container video-intro__inner">

    <!-- Left: text -->
    <div class="video-intro__content">
      <span class="label-eyebrow">Schauen Sie selbst</span>
      <h2 id="video-intro-heading" class="video-intro__title">Verstehen in 90 Sekunden</h2>
      <p class="video-intro__desc">
        Ein kurzer Einstieg – damit Sie wissen, was Sie erwartet, bevor Sie starten.
      </p>

      <ul class="video-intro__expectations" role="list">
        {expectations.map((item) => (
          <li class="video-intro__expect-item">
            <span class="video-intro__check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="8" fill="var(--color-primary-soft)"/>
                <polyline points="4.5,8 7,10.5 11.5,5.5" stroke="var(--color-primary)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>

      <p class="video-intro__inline-text">
        Sie starten mit einem kurzen Selbsttest, folgen dann interaktiven Lernpfaden
        zu den Themen die Sie interessieren – und können jederzeit pausieren,
        wiederholen und in Ihrem eigenen Tempo weitermachen.
      </p>
    </div>

    <!-- Right: video -->
    <div class="video-intro__player-wrap">
      <div class="video-intro__player">
        {embedUrl ? (
          <iframe
            src={embedUrl}
            title="Verstehen in 90 Sekunden – medienkundig Einführungsvideo"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="video-intro__iframe"
          ></iframe>
        ) : (
          <div class="video-intro__placeholder" id="video-placeholder">
            <!-- in-player badges -->
            <span class="video-intro__badge video-intro__badge--duration">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M6 3.5V6l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              90 Sek.
            </span>
            <span class="video-intro__badge video-intro__badge--subs">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <rect x="1" y="2.5" width="10" height="7" rx="1.2" stroke="currentColor" stroke-width="1.2"/>
                <rect x="2.5" y="5.5" width="2.5" height="1" rx="0.5" fill="currentColor"/>
                <rect x="6.5" y="5.5" width="3" height="1" rx="0.5" fill="currentColor"/>
                <rect x="2.5" y="7.2" width="4" height="1" rx="0.5" fill="currentColor"/>
              </svg>
              Untertitel
            </span>

            <img
              src={posterSrc}
              alt=""
              class="video-intro__poster"
              width="1280"
              height="720"
              loading="lazy"
            />
            <button
              class="video-intro__play"
              type="button"
              aria-label="Video abspielen: Verstehen in 90 Sekunden"
              id="play-btn"
            >
              <span class="video-intro__play-ring" aria-hidden="true"></span>
              <span class="video-intro__play-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                  <path d="M10 7.5L21 14L10 20.5V7.5Z" fill="currentColor"/>
                </svg>
              </span>
            </button>
          </div>
        )}

        {videoSrc && (
          <video
            src={videoSrc}
            poster={posterSrc}
            controls
            preload="none"
            class="video-intro__video visually-hidden"
            id="video-el"
            aria-label="Verstehen in 90 Sekunden – medienkundig Einführungsvideo"
          >
            <track kind="captions" label="Deutsch" srclang="de" default />
            Ihr Browser unterstützt kein HTML-Video.
          </video>
        )}
      </div>
    </div>

  </div>
</section>

<script>
  const placeholder = document.getElementById("video-placeholder");
  const videoEl = document.getElementById("video-el") as HTMLVideoElement | null;

  if (placeholder && videoEl) {
    document.getElementById("play-btn")?.addEventListener("click", () => {
      placeholder.classList.add("visually-hidden");
      videoEl.classList.remove("visually-hidden");
      videoEl.play();
    });
  }
</script>
