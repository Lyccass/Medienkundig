---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Button from "@/components/Button.astro";
import DirectoryLayout from "@/components/DirectoryLayout.astro";
import DirectoryGroup from "@/components/DirectoryGroup.astro";
import DirectoryRow from "@/components/DirectoryRow.astro";

const appUrl = "http://app.medienkundig.local";

const categories = [
  {
    number: "01",
    title: "Digitale Grundlagen",
    description: "Was ist eine Domain? Woran erkenne ich einen seriösen Link? Wie sieht ein sicheres Passwort aus? Der erste Themenbereich erklärt die Basis – alles, was man braucht, um sich sicherer im Netz zu bewegen.",
    count: "7 Übungen",
  },
  {
    number: "02",
    title: "Betrug erkennen",
    description: "Phishing-Mails, gefälschte Anrufe, Fake-Shops, der Enkeltrick – die Maschen sind vielfältig, aber die Muster sind lernbar. Wer sie kennt, erkennt sie auch im echten Alltag.",
    count: "9 Übungen",
  },
  {
    number: "03",
    title: "News & Quellen prüfen",
    description: "Nicht alles, was viral geht, stimmt auch. Dieser Themenbereich zeigt, wie man eine Quelle einschätzt, Faktencheck-Portale nutzt und Falschmeldungen von seriöser Berichterstattung unterscheidet.",
    count: "5 Übungen",
  },
  {
    number: "04",
    title: "Social Media verstehen",
    description: "Algorithmen, Filterblase, Datenschutz – was passiert hinter den Kulissen der Plattformen, die wir täglich nutzen? Und wie gehe ich dort bewusst und sicher mit meinen Daten um?",
    count: "5 Übungen",
  },
];

const steps = [
  {
    number: "01",
    title: "Einstufungstest",
    description:
      "20 kurze Fragen ohne Vorkenntnisse. Am Ende bekommst du ein Level: Einsteiger, Fortgeschritten oder Sicher.",
  },
  {
    number: "02",
    title: "Thema wählen",
    description:
      "medienkundig empfiehlt dir einen Startpunkt. Du kannst aber jederzeit frei zwischen den vier Themenbereichen wechseln.",
  },
  {
    number: "03",
    title: "Interaktive Übungen",
    description:
      "Multiple Choice, URL-Trainer, Fallszenarien, Warnzeichen-Übungen und Memory wechseln sich ab.",
  },
  {
    number: "04",
    title: "Wiederholen & festigen",
    description:
      "Abgeschlossene Übungen bleiben verfügbar. Fortschritt, XP und Tages-Serie helfen beim Dranbleiben.",
  },
];

const navItems = [
  { href: "#themen", label: "Themen", count: String(categories.length) },
  { href: "#ablauf", label: "Ablauf", count: String(steps.length) },
];
---

<BaseLayout
  title="Lernpfade – medienkundig"
  description="Vier Themenbereiche, interaktive Übungen und ein kurzer Einstufungstest – so funktioniert medienkundig."
>
  <PageHeader
    eyebrow="Wie es funktioniert"
    title="Lernen, was im Alltag zählt"
    subtitle="Kurzer Einstufungstest, dann direkt in das passende Thema. Keine Anmeldung nötig."
  >
    <Button href={appUrl} variant="primary" size="sm">Einstufungstest starten</Button>
  </PageHeader>

  <DirectoryLayout navLabel="Lernseite" navItems={navItems}>
    <DirectoryGroup id="themen" marker="01" title="Themenbereiche">
      <ul class="directory-list" role="list">
        {categories.map((cat) => (
          <DirectoryRow
            index={cat.number}
            title={cat.title}
            description={cat.description}
            meta={cat.count}
          />
        ))}
      </ul>
    </DirectoryGroup>

    <DirectoryGroup id="ablauf" marker="02" title="So läuft eine Lerneinheit ab">
      <ol class="directory-list" role="list">
        {steps.map((step) => (
          <DirectoryRow
            index={step.number}
            title={step.title}
            description={step.description}
          />
        ))}
      </ol>
      <div class="directory-action">
        <Button href={appUrl} variant="primary" size="lg">Jetzt loslegen</Button>
      </div>
    </DirectoryGroup>
  </DirectoryLayout>
</BaseLayout>
