---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import Button from "@/components/Button.astro";

const appUrl = "http://app.medienkundig.local";

const categories = [
  {
    number: "01",
    title: "Digitale Grundlagen",
    description: "Was ist eine Domain? Woran erkenne ich einen seriösen Link? Wie sieht ein sicheres Passwort aus? Der erste Themenbereich erklärt die Basis – alles, was man braucht, um sich sicherer im Netz zu bewegen.",
    count: "7 Übungen",
  },
  {
    number: "02",
    title: "Betrug erkennen",
    description: "Phishing-Mails, gefälschte Anrufe, Fake-Shops, der Enkeltrick – die Maschen sind vielfältig, aber die Muster sind lernbar. Wer sie kennt, erkennt sie auch im echten Alltag.",
    count: "9 Übungen",
  },
  {
    number: "03",
    title: "News & Quellen prüfen",
    description: "Nicht alles, was viral geht, stimmt auch. Dieser Themenbereich zeigt, wie man eine Quelle einschätzt, Faktencheck-Portale nutzt und Falschmeldungen von seriöser Berichterstattung unterscheidet.",
    count: "5 Übungen",
  },
  {
    number: "04",
    title: "Social Media verstehen",
    description: "Algorithmen, Filterblase, Datenschutz – was passiert hinter den Kulissen der Plattformen, die wir täglich nutzen? Und wie gehe ich dort bewusst und sicher mit meinen Daten um?",
    count: "5 Übungen",
  },
];
---

<BaseLayout
  title="Lernpfade – medienkundig"
  description="Vier Themenbereiche, interaktive Übungen und ein kurzer Einstufungstest – so funktioniert medienkundig."
>
  <PageHeader
    eyebrow="Wie es funktioniert"
    title="Lernen, was im Alltag zählt"
    subtitle="Kurzer Einstufungstest, dann direkt in das passende Thema. Keine Anmeldung nötig."
  >
    <div class="lp-head-cta">
      <Button href={appUrl} variant="primary" size="sm">Einstufungstest starten</Button>
    </div>
  </PageHeader>

  <!-- Categories -->
  <section class="section container">
    <div class="lp-section-header">
      <span class="label-eyebrow">Themenbereiche</span>
      <h2 class="lp-section-title">Vier Themen, eine Plattform</h2>
    </div>
    <ul class="lp-cats" role="list">
      {categories.map((cat) => (
        <li class="lp-cat">
          <span class="lp-cat__number">{cat.number}</span>
          <div class="lp-cat__body">
            <div class="lp-cat__head">
              <h3 class="lp-cat__title">{cat.title}</h3>
              <span class="lp-cat__count">{cat.count}</span>
            </div>
            <p class="lp-cat__desc">{cat.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- How it works -->
  <section class="section section--tinted">
    <div class="container lp-how">
      <div class="lp-section-header">
        <span class="label-eyebrow">Der Ablauf</span>
        <h2 class="lp-section-title">So läuft eine Lerneinheit ab</h2>
      </div>
      <ol class="lp-steps" role="list">
        <li class="lp-step">
          <span class="lp-step__num" aria-hidden="true">1</span>
          <div class="lp-step__body">
            <strong>Einstufungstest</strong>
            <p>20 kurze Fragen – keine Vorkenntnisse nötig. Am Ende bekommst du ein Level: Einsteiger, Fortgeschritten oder Sicher.</p>
          </div>
        </li>
        <li class="lp-step">
          <span class="lp-step__num" aria-hidden="true">2</span>
          <div class="lp-step__body">
            <strong>Thema wählen</strong>
            <p>Wir empfehlen dir einen Startpunkt basierend auf deinem Ergebnis. Du kannst aber auch frei zwischen den vier Themenbereichen wählen.</p>
          </div>
        </li>
        <li class="lp-step">
          <span class="lp-step__num" aria-hidden="true">3</span>
          <div class="lp-step__body">
            <strong>Interaktive Übungen</strong>
            <p>Multiple Choice, URL-Trainer, Fallszenarien, Memory – jede Lektion wechselt zwischen verschiedenen Formaten, damit es nicht eintönig wird.</p>
          </div>
        </li>
        <li class="lp-step">
          <span class="lp-step__num" aria-hidden="true">4</span>
          <div class="lp-step__body">
            <strong>Wiederholen &amp; festigen</strong>
            <p>Bereits abgeschlossene Übungen kannst du jederzeit wiederholen. XP und eine Tages-Serie zeigen, wie regelmäßig du übst.</p>
          </div>
        </li>
      </ol>
      <div class="lp-cta">
        <Button href={appUrl} variant="primary" size="lg">Jetzt loslegen</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lp-head-cta {
    margin-top: var(--space-2);
  }

  /* ── Section header ── */
  .lp-section-header {
    margin-bottom: var(--space-8);
  }

  .lp-section-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-top: var(--space-2);
  }

  /* ── Categories ── */
  .lp-cats {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .lp-cat {
    display: flex;
    gap: var(--space-8);
    align-items: flex-start;
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .lp-cat__number {
    flex-shrink: 0;
    font-size: var(--text-sm);
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    opacity: 0.5;
    padding-top: 4px;
    width: 2rem;
  }

  .lp-cat__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .lp-cat__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .lp-cat__title {
    font-size: var(--text-xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .lp-cat__count {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .lp-cat__desc {
    font-size: var(--text-base);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
    max-width: 70ch;
  }

  /* ── How it works ── */
  .lp-how {
    max-width: 760px;
  }

  .lp-steps {
    list-style: none;
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-10);
  }

  .lp-step {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    padding-block: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  .lp-step__num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 3px;
  }

  .lp-step__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .lp-step__body strong {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
  }

  .lp-step__body p {
    font-size: var(--text-base);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
  }

  .lp-cta {
    margin-top: var(--space-4);
  }

  @media (max-width: 600px) {
    .lp-cat {
      flex-direction: column;
      gap: var(--space-3);
    }
    .lp-cat__number {
      padding-top: 0;
    }
  }
</style>
