---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
---

<BaseLayout
  title="Über uns – medienkundig"
  description="medienkundig ist eine Bachelorarbeit von Jacquline Lehmann und Luka Sandvoß im Studiengang Mediendesign, 2026."
>
  <PageHeader
    eyebrow="Das Projekt"
    title="Über medienkundig"
  />

  <div class="container ou-body">

    <section class="ou-section">
      <h2 class="ou-h2">Worum es geht</h2>
      <p>
        medienkundig ist eine interaktive Lernplattform zur digitalen Medienkompetenz.
        Sie entstand als Bachelorarbeit im Studiengang Mediendesign an der <strong>[Hochschule]</strong> und wurde 2026 eingereicht.
      </p>
      <p>
        Ausgangspunkt war eine einfache Beobachtung: Wer nicht mit dem Internet aufgewachsen ist, hatte oft keine
        Gelegenheit, den Umgang damit systematisch zu lernen. Gefälschte E-Mails, irreführende Nachrichten oder
        unsichere Passwörter – das sind reale Risiken, auf die viele Menschen nicht vorbereitet sind. Nicht weil
        sie unvorsichtig sind, sondern weil ihnen die richtigen Werkzeuge fehlen.
      </p>
      <p>
        medienkundig setzt genau da an. Die Plattform richtet sich an Menschen ab 50, die sicherer mit digitalen
        Medien umgehen wollen – mit echten Beispielen aus dem Alltag, ohne Fachsprache.
      </p>
    </section>

    <section class="ou-section">
      <h2 class="ou-h2">Die Macherinnen und Macher</h2>
      <ul class="ou-team" role="list">
        <li class="ou-person">
          <div class="ou-person__name-row">
            <strong class="ou-person__name">Jacquline Lehmann</strong>
            <span class="ou-person__role">Konzept, Inhalt &amp; Redaktion</span>
          </div>
          <p class="ou-person__desc">
            Jacquline hat die Lerninhalte konzipiert, recherchiert und aufbereitet – von den Themengebieten
            über die Übungsformate bis hin zu den konkreten Aufgaben und Erklärungen.
          </p>
        </li>
        <li class="ou-person">
          <div class="ou-person__name-row">
            <strong class="ou-person__name">Luka Sandvoß</strong>
            <span class="ou-person__role">Design &amp; Entwicklung</span>
          </div>
          <p class="ou-person__desc">
            Luka hat das visuelle Konzept, die Informationsarchitektur und die technische Umsetzung
            der Plattform verantwortet – von der Lern-App über diese Website bis hin zum Backend.
          </p>
        </li>
      </ul>
    </section>

    <section class="ou-section">
      <h2 class="ou-h2">Unser Ansatz</h2>
      <p>
        Medienkompetenz ist keine Frage des Alters – aber ältere Generationen hatten häufig weniger
        Berührungspunkte mit digitalem Lernen. Unser Ansatz: kurze Einheiten, greifbare Beispiele,
        kein Überfordern. Fortschritt wird lokal gespeichert, ein Konto ist optional.
      </p>
      <p>
        Die Inhalte basieren auf Quellen wie dem BSI, der Bundeszentrale für politische Bildung und Klicksafe –
        aufbereitet so, dass sie ohne Vorkenntnisse verständlich sind. Alle Quellen sind auf der
        <a href="/quellen" class="ou-link">Quellenseite</a> gesammelt.
      </p>
    </section>

  </div>
</BaseLayout>

<style>
  .ou-body {
    max-width: 720px;
    padding-block: var(--space-12) var(--space-20);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ou-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-block: var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  .ou-section:first-child {
    border-top: 1px solid var(--color-border);
  }

  .ou-section:last-child {
    border-bottom: none;
  }

  .ou-h2 {
    font-size: var(--text-xl);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .ou-section p {
    font-size: var(--text-base);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
  }

  .ou-link {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Team list */
  .ou-team {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .ou-person {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .ou-person:first-child {
    border-top: 1px solid var(--color-border);
  }

  .ou-person__name-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .ou-person__name {
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .ou-person__role {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ou-person__desc {
    font-size: var(--text-base);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
    max-width: 60ch;
  }
</style>
