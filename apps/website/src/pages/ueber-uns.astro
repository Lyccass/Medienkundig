---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import DirectoryLayout from "@/components/DirectoryLayout.astro";
import DirectoryGroup from "@/components/DirectoryGroup.astro";
import DirectoryRow from "@/components/DirectoryRow.astro";

const teamMembers = [
  {
    name: "Jacquline Lehmann",
    role: "Konzept, Inhalt & Redaktion",
    description:
      "Jacquline hat die Lerninhalte konzipiert, recherchiert und aufbereitet – von den Themengebieten über die Übungsformate bis hin zu den konkreten Aufgaben und Erklärungen.",
  },
  {
    name: "Luka Sandvoß",
    role: "Design & Entwicklung",
    description:
      "Luka hat das visuelle Konzept, die Informationsarchitektur und die technische Umsetzung der Plattform verantwortet – von der Lern-App über diese Website bis hin zum Backend.",
  },
];

const navItems = [
  { href: "#projekt", label: "Projekt" },
  { href: "#team", label: "Team", count: String(teamMembers.length) },
  { href: "#ansatz", label: "Ansatz" },
];
---

<BaseLayout
  title="Über uns – medienkundig"
  description="medienkundig ist eine Bachelorarbeit von Jacquline Lehmann und Luka Sandvoß im Studiengang Mediendesign, 2026."
>
  <PageHeader
    eyebrow="Das Projekt"
    title="Über medienkundig"
  />

  <DirectoryLayout navLabel="Über uns" navItems={navItems}>
    <DirectoryGroup id="projekt" marker="01" title="Worum es geht">
      <div class="directory-copy">
        <p>
          medienkundig ist eine interaktive Lernplattform zur digitalen Medienkompetenz.
          Sie entstand als Bachelorarbeit im Studiengang Mediendesign an der <strong>[Hochschule]</strong> und wurde 2026 eingereicht.
        </p>
        <p>
          Ausgangspunkt war eine einfache Beobachtung: Wer nicht mit dem Internet aufgewachsen ist, hatte oft keine
          Gelegenheit, den Umgang damit systematisch zu lernen. Gefälschte E-Mails, irreführende Nachrichten oder
          unsichere Passwörter sind reale Risiken, auf die viele Menschen nicht vorbereitet sind.
        </p>
        <p>
          medienkundig setzt genau da an. Die Plattform richtet sich an Menschen ab 50, die sicherer mit digitalen
          Medien umgehen wollen: mit echten Beispielen aus dem Alltag, ohne Fachsprache.
        </p>
      </div>
    </DirectoryGroup>

    <DirectoryGroup id="team" marker="02" title="Die Macherinnen und Macher">
      <ul class="directory-list" role="list">
        {teamMembers.map((member) => (
          <DirectoryRow
            title={member.name}
            description={member.description}
            meta={member.role}
          />
        ))}
      </ul>
    </DirectoryGroup>

    <DirectoryGroup id="ansatz" marker="03" title="Unser Ansatz">
      <div class="directory-copy">
        <p>
          Medienkompetenz ist keine Frage des Alters. Unser Ansatz: kurze Einheiten, greifbare Beispiele
          und klare Rückmeldung, ohne zu überfordern. Fortschritt wird lokal gespeichert, ein Konto ist optional.
        </p>
        <p>
          Die Inhalte basieren auf Quellen wie dem BSI, der Bundeszentrale für politische Bildung und Klicksafe.
          Alle Quellen sind auf der <a href="/quellen">Quellenseite</a> gesammelt.
        </p>
      </div>
    </DirectoryGroup>
  </DirectoryLayout>
</BaseLayout>
