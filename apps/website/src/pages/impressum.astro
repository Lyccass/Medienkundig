---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ContentFrame from "@/components/ContentFrame.astro";
import ContentSection from "@/components/ContentSection.astro";
---

<BaseLayout
  title="Impressum – medienkundig"
  description="Angaben gemäß § 5 TMG"
>
  <PageHeader eyebrow="Rechtliches" title="Impressum" />

  <ContentFrame width="legal">
    <ContentSection title="Angaben gemäß § 5 TMG" tone="legal">
      <p>
        Luka Sandvoß &amp; Jacquline Lehmann<br />
        [Straße und Hausnummer]<br />
        [PLZ] [Stadt]<br />
        Deutschland
      </p>
    </ContentSection>

    <ContentSection title="Kontakt" tone="legal">
      <p>E-Mail: [E-Mail-Adresse]</p>
    </ContentSection>

    <ContentSection title="Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV" tone="legal">
      <p>
        Luka Sandvoß &amp; Jacquline Lehmann<br />
        [Adresse wie oben]
      </p>
    </ContentSection>

    <ContentSection title="Hinweis" tone="legal">
      <p>
        Diese Website ist ein Hochschulprojekt im Rahmen einer Bachelorarbeit an der [Hochschule],
        Studiengang Mediendesign, 2026. Sie verfolgt keine kommerziellen Zwecke.
      </p>
    </ContentSection>

    <ContentSection title="Haftungsausschluss" tone="legal">
      <p>
        Die Inhalte dieser Website wurden mit größter Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit
        und Aktualität können wir jedoch keine Gewähr übernehmen. Für externe Links sind ausschließlich
        deren Betreiber verantwortlich.
      </p>
    </ContentSection>
  </ContentFrame>
</BaseLayout>
