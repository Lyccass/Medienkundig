---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { glossarTerms, glossarCategories } from "@medienkundig/ui";

const sorted = [...glossarTerms].sort((a, b) => a.term.localeCompare(b.term, "de"));

// Group alphabetically
const grouped: Record<string, typeof sorted> = {};
for (const term of sorted) {
  const letter = term.term[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(term);
}
const letters = Object.keys(grouped).sort();
---

<BaseLayout
  title="Glossar – medienkundig"
  description="Alle wichtigen Begriffe rund um Medienkompetenz, einfach erklärt."
>
  <div class="gp">

    <!-- Page header -->
    <div class="gp__head">
      <div class="container gp__head-inner">
        <div class="gp__head-text">
          <span class="label-eyebrow">Nachschlagen</span>
          <h1 class="gp__title">Glossar</h1>
          <p class="gp__sub">{glossarTerms.length} Begriffe rund um Medienkompetenz, einfach erklärt.</p>
        </div>
        <div class="gp__search-wrap">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="gp__search-icon">
            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.6"/>
            <path d="M12.5 12.5l3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          <input id="gp-search" type="search" placeholder="Begriff suchen…" class="gp__search" autocomplete="off" />
        </div>
      </div>
      <!-- Arch wave transition to white -->
      <div class="gp__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
          <path d="M0,80 C360,80 720,0 1440,0 L1440,80 Z" fill="#ffffff"/>
        </svg>
      </div>
    </div>

    <!-- Two-pane body -->
    <div class="container gp__body">

      <!-- Sidebar -->
      <aside class="gp__sidebar">
        <p class="gp__sidebar-label">Kategorien</p>
        <nav class="gp__cat-nav">
          <button class="gp__cat gp__cat--active" data-filter="all" type="button">
            <span class="gp__cat-dot"></span>Alle
            <span class="gp__cat-count">{glossarTerms.length}</span>
          </button>
          {(glossarCategories as string[]).map((cat) => (
            <button class="gp__cat" data-filter={cat} type="button">
              <span class="gp__cat-dot"></span>{cat}
              <span class="gp__cat-count">{glossarTerms.filter(t => t.category === cat).length}</span>
            </button>
          ))}
        </nav>

        <div class="gp__alpha-nav">
          {letters.map((l) => (
            <a class="gp__alpha-link" href={`#letter-${l}`}>{l}</a>
          ))}
        </div>
      </aside>

      <!-- Main list -->
      <main class="gp__main">
        {letters.map((letter) => (
          <div class="gp__group" id={`letter-${letter}`} data-letter={letter}>
            <div class="gp__letter">{letter}</div>
            <ul class="gp__list" role="list">
              {grouped[letter].map((term) => (
                <li
                  class="gp__row"
                  data-category={term.category}
                  data-search={`${term.term} ${term.short}`.toLowerCase()}
                >
                  <button class="gp__row-btn" data-glossar={term.id} type="button">
                    <div class="gp__row-left">
                      <span class="gp__row-term">{term.term}</span>
                      <span class="gp__row-short">{term.short}</span>
                    </div>
                    <div class="gp__row-right">
                      <span class="gp__row-cat">{term.category}</span>
                      <svg class="gp__row-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M4 8h8M9 5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <p class="gp__empty" id="gp-empty" hidden>Kein Begriff gefunden.</p>
      </main>

    </div>
  </div>
</BaseLayout>

<style>
  /* ── Page header ── */
  .gp__head {
    background: var(--color-primary-soft);
    padding-block: var(--space-16) 0;
    position: relative;
  }

  .gp__wave {
    line-height: 0;
    margin-top: var(--space-10);
  }
  .gp__wave svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  .gp__head-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .gp__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-text);
    line-height: 1;
    margin-top: var(--space-2);
  }

  .gp__sub {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-2);
  }

  /* Search */
  .gp__search-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .gp__search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-muted);
    pointer-events: none;
  }

  .gp__search {
    width: 280px;
    padding: 10px 16px 10px 40px;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .gp__search:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-soft);
  }

  /* ── Two-pane ── */
  .gp__body {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    padding-block: var(--space-10) var(--space-20);
    align-items: start;
  }

  /* ── Sidebar ── */
  .gp__sidebar {
    position: sticky;
    top: calc(var(--header-height, 64px) + 24px);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .gp__sidebar-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin: 0;
  }

  .gp__cat-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gp__cat {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 7px 10px;
    border-radius: var(--radius-md);
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-soft);
    cursor: pointer;
    text-align: left;
    transition: background 0.12s, color 0.12s;
  }
  .gp__cat:hover { background: var(--color-surface-soft); color: var(--color-text); }
  .gp__cat--active {
    background: var(--color-primary-soft);
    color: var(--color-primary);
    font-weight: 700;
  }
  .gp__cat--active .gp__cat-dot { background: var(--color-primary); }

  .gp__cat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-border-strong);
    flex-shrink: 0;
    transition: background 0.12s;
  }

  .gp__cat-count {
    margin-left: auto;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-muted);
    background: var(--color-surface-soft);
    padding: 1px 7px;
    border-radius: 99px;
  }
  .gp__cat--active .gp__cat-count {
    background: rgba(108,63,255,0.15);
    color: var(--color-primary);
  }

  /* Alpha quick-nav */
  .gp__alpha-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .gp__alpha-link {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-muted);
    text-decoration: none;
    transition: background 0.12s, color 0.12s;
  }
  .gp__alpha-link:hover {
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }

  /* ── Main term list ── */
  .gp__group {
    margin-bottom: var(--space-10);
  }
  .gp__group[hidden] { display: none; }

  .gp__letter {
    font-size: 2.5rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--color-primary);
    opacity: 0.2;
    line-height: 1;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1.5px solid var(--color-border);
  }

  .gp__list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .gp__row { border-bottom: 1px solid var(--color-border); }
  .gp__row[hidden] { display: none; }

  .gp__row-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    width: 100%;
    padding: var(--space-4) var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s;
    border-radius: var(--radius-sm);
  }
  .gp__row-btn:hover { background: var(--color-surface-soft); }
  .gp__row-btn:hover .gp__row-arrow { opacity: 1; transform: translateX(3px); }

  .gp__row-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .gp__row-term {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .gp__row-short {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 52ch;
  }

  .gp__row-right {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .gp__row-cat {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .gp__row-arrow {
    color: var(--color-primary);
    opacity: 0.3;
    transition: opacity 0.15s, transform 0.15s;
    flex-shrink: 0;
  }

  /* Empty state */
  .gp__empty {
    padding: var(--space-16) 0;
    color: var(--color-muted);
    font-size: var(--text-md);
    text-align: center;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .gp__body { grid-template-columns: 1fr; }
    .gp__sidebar { position: static; flex-direction: row; flex-wrap: wrap; align-items: center; }
    .gp__cat-nav { flex-direction: row; flex-wrap: wrap; }
    .gp__alpha-nav { display: none; }
    .gp__head { position: static; }
  }

  @media (max-width: 600px) {
    .gp__head-inner { flex-direction: column; align-items: flex-start; }
    .gp__search { width: 100%; }
    .gp__search-wrap { width: 100%; }
    .gp__row-right { display: none; }
  }
</style>

<script>
  const searchInput = document.getElementById("gp-search") as HTMLInputElement;
  const filterBtns  = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-filter]"));
  const groups      = Array.from(document.querySelectorAll<HTMLElement>(".gp__group"));
  const emptyMsg    = document.getElementById("gp-empty") as HTMLElement;

  let activeFilter = "all";
  let query = "";

  function applyFilters() {
    let totalVisible = 0;

    groups.forEach((group) => {
      const groupRows = Array.from(group.querySelectorAll<HTMLElement>(".gp__row"));
      let groupVisible = 0;

      groupRows.forEach((row) => {
        const matchCat    = activeFilter === "all" || row.dataset.category === activeFilter;
        const matchSearch = !query || (row.dataset.search ?? "").includes(query);
        const show = matchCat && matchSearch;
        row.hidden = !show;
        if (show) groupVisible++;
      });

      group.hidden = groupVisible === 0;
      totalVisible += groupVisible;
    });

    emptyMsg.hidden = totalVisible > 0;
  }

  searchInput.addEventListener("input", () => {
    query = searchInput.value.toLowerCase().trim();
    applyFilters();
  });

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterBtns.forEach((b) => b.classList.remove("gp__cat--active"));
      btn.classList.add("gp__cat--active");
      activeFilter = btn.dataset.filter!;
      applyFilters();
    });
  });
</script>
