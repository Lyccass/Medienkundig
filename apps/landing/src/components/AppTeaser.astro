---
import Button from "./Button.astro";
---

<section class="section app-teaser" aria-labelledby="app-teaser-heading">
  <div class="container">
    <div class="app-teaser__inner">

      <!-- Left: content -->
      <div class="app-teaser__content">
        <span class="label-eyebrow">Immer dabei, immer informiert</span>
        <h2 id="app-teaser-heading" class="app-teaser__title">
          Lernen, wann es passt.
        </h2>
        <p class="app-teaser__text">
          Die medienkundig App begleitet Sie mit kurzen Übungen, Fortschritt und
          Wiederholungen – am Smartphone, Tablet oder Desktop.
        </p>
        <Button href="https://app.medienkundig.local" variant="primary" size="lg">
          Zur App
        </Button>
      </div>

      <!-- Right: app mockup image -->
      <div class="app-teaser__visual" aria-hidden="true">
        <img
          src="/assets/app-mockup.png"
          alt=""
          class="app-teaser__mockup"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .app-teaser {
    background-color: var(--color-primary-soft);
    border-radius: var(--radius-xl);
    margin-inline: clamp(var(--space-4), 4vw, var(--space-12));
    overflow: hidden;
  }

  .app-teaser__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    padding-block: var(--space-16);
  }

  /* ── Content ── */
  .app-teaser__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }

  .app-teaser__title {
    font-size: var(--text-4xl);
    color: var(--color-text);
  }

  .app-teaser__text {
    font-size: var(--text-md);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
    max-width: 40ch;
  }

  /* ── App mockup image ── */
  .app-teaser__visual {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .app-teaser__mockup {
    width: 100%;
    max-width: 520px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 24px 48px rgba(108, 63, 255, 0.18));
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .app-teaser {
      margin-inline: var(--space-4);
      border-radius: var(--radius-lg);
    }

    .app-teaser__inner {
      grid-template-columns: 1fr;
    }

    .app-teaser__content {
      align-items: center;
      text-align: center;
    }

    .app-teaser__text {
      max-width: none;
    }

    .app-teaser__visual {
      justify-content: center;
    }

    .app-teaser__mockup {
      max-width: 380px;
    }
  }

  @media (max-width: 480px) {
    .app-teaser__visual {
      display: none;
    }
  }
</style>
