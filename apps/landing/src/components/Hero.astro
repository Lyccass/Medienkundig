---
import Button from "./Button.astro";

const onboardingUrl = "http://app.medienkundig.local?onboarding=1";
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="container hero__inner">

    <!-- Left: content -->
    <div class="hero__content">
      <span class="hero__eyebrow">Medienkompetenz für jeden</span>

      <h1 id="hero-heading" class="hero__heading">
        Verstehen. Erkennen.<br />
        <span class="hero__heading--accent">Sicher Bleiben.</span>
      </h1>

      <p class="hero__body">
        Interaktive Lernpfade die dich für den digitalen Alltag stark machen.
      </p>

      <div class="hero__actions">
        <Button href={onboardingUrl} variant="primary" size="lg">Zum Selbsttest</Button>
        <Button href={onboardingUrl} variant="secondary" size="lg">Erste Schritte</Button>
      </div>

      <div class="hero__rating" aria-label="4,9 von 5 Sternen – Von über 12.000 Lernenden empfohlen">
        <div class="hero__avatars" aria-hidden="true">
          <span class="hero__avatar hero__avatar--1"></span>
          <span class="hero__avatar hero__avatar--2"></span>
          <span class="hero__avatar hero__avatar--3"></span>
        </div>
        <div class="hero__rating-text">
          <span class="hero__stars" aria-hidden="true">★★★★★</span>
          <span class="hero__rating-score">4,9/5</span>
          <span class="hero__rating-label">Von über 12.000 Lernenden empfohlen</span>
        </div>
      </div>
    </div>

    <!-- Right: visual -->
    <div class="hero__visual" aria-hidden="true">
      <!-- decorative rings -->
      <div class="hero__ring hero__ring--outer"></div>
      <div class="hero__ring hero__ring--inner"></div>

      <!-- mascot -->
      <img
        src="/assets/tinty.png"
        alt=""
        class="hero__mascot"
        width="380"
        height="380"
        loading="eager"
      />

      <!-- chips – absolutely positioned around the ring -->
      <span class="hero__chip hero__chip--top hero__chip--pink" data-glossar="phishing" role="button" tabindex="0" title="Phishing nachschlagen">
        <span class="hero__chip-dot"></span>Phishing
      </span>
      <span class="hero__chip hero__chip--left-top hero__chip--lavender" data-glossar="deepfake" role="button" tabindex="0" title="Deepfake nachschlagen">
        <span class="hero__chip-dot"></span>Deepfake
      </span>
      <span class="hero__chip hero__chip--left-mid hero__chip--teal" data-glossar="fake-news" role="button" tabindex="0" title="Fake News nachschlagen">
        <span class="hero__chip-dot"></span>Fake News
      </span>
      <span class="hero__chip hero__chip--left-bottom hero__chip--purple" data-glossar="ki" role="button" tabindex="0" title="KI nachschlagen">
        <span class="hero__chip-dot"></span>KI & Co
      </span>
      <span class="hero__chip hero__chip--right-bottom hero__chip--amber" data-glossar="dsgvo" role="button" tabindex="0" title="Datenschutz nachschlagen">
        <span class="hero__chip-dot"></span>Datenschutz
      </span>
    </div>

  </div>

  <div class="hero__scroll-hint" aria-hidden="true">
    <svg class="hero__scroll-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path d="M6 9l6 6 6-6" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- wave transition to white sections below -->
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,120 C300,120 600,0 1200,0 L1440,0 L1440,120 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding-block: var(--space-12);
  }

  /* gradient glow – stronger right-side purple blob like reference */
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 65% at 72% 45%, rgba(180, 150, 255, 0.45) 0%, transparent 65%),
      radial-gradient(ellipse 40% 50% at 85% 70%, rgba(200, 170, 255, 0.2) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Layout ── */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: var(--space-8);
    align-items: center;
  }

  /* ── Content side ── */
  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    background-color: var(--color-primary-soft);
    border: 1.5px solid var(--color-border);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.01em;
  }

  .hero__heading {
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .hero__heading--accent {
    color: var(--color-primary);
  }

  .hero__body {
    font-size: var(--text-md);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
    max-width: 40ch;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* Rating */
  .hero__rating {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .hero__avatars {
    display: flex;
    align-items: center;
  }

  .hero__avatar {
    display: block;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2.5px solid var(--color-bg);
    margin-left: -10px;
    flex-shrink: 0;
  }

  .hero__avatar:first-child { margin-left: 0; }

  .hero__avatar--1 { background: linear-gradient(135deg, #f9a8d4, #e879a5); }
  .hero__avatar--2 { background: linear-gradient(135deg, #86efac, #22c55e); }
  .hero__avatar--3 { background: linear-gradient(135deg, #fbbf24, #f59e0b); }

  .hero__rating-text {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .hero__stars {
    color: #f59e0b;
    font-size: var(--text-base);
    letter-spacing: -1px;
  }

  .hero__rating-score {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
  }

  .hero__rating-label {
    font-size: var(--text-sm);
    color: var(--color-muted);
    width: 100%;
    margin-top: -var(--space-1);
  }

  /* ── Visual side ── */
  .hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: clamp(380px, 55vw, 580px);
  }

  /* Decorative rings */
  .hero__ring {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .hero__ring--outer {
    width: 90%;
    aspect-ratio: 1;
    border: 1.5px solid rgba(108, 63, 255, 0.15);
  }

  .hero__ring--inner {
    width: 65%;
    aspect-ratio: 1;
    border: 1px solid rgba(108, 63, 255, 0.08);
  }

  /* Mascot */
  .hero__mascot {
    position: relative;
    z-index: 2;
    width: clamp(220px, 28vw, 380px);
    height: auto;
    filter: drop-shadow(0 20px 60px rgba(108, 63, 255, 0.2));
  }

  /* Chips */
  .hero__chip {
    position: absolute;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-soft);
    box-shadow: var(--shadow-soft);
    white-space: nowrap;
    cursor: help;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .hero__chip:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card);
  }

  .hero__chip-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Per-chip colour theming */
  .hero__chip--pink {
    background-color: #fce7f3;
    border: 1.5px solid #fbcfe8;
  }
  .hero__chip--pink .hero__chip-dot     { background-color: #f472b6; }

  .hero__chip--lavender {
    background-color: #f3f0ff;
    border: 1.5px solid #ddd6fe;
  }
  .hero__chip--lavender .hero__chip-dot { background-color: #a78bfa; }

  .hero__chip--teal {
    background-color: #ecfdf5;
    border: 1.5px solid #a7f3d0;
  }
  .hero__chip--teal .hero__chip-dot     { background-color: #34d399; }

  .hero__chip--purple {
    background-color: #ede9fe;
    border: 1.5px solid #c4b5fd;
  }
  .hero__chip--purple .hero__chip-dot   { background-color: #8b5cf6; }

  .hero__chip--amber {
    background-color: #fffbeb;
    border: 1.5px solid #fde68a;
  }
  .hero__chip--amber .hero__chip-dot    { background-color: #fbbf24; }

  /* Chip positions – 5 chips orbiting the mascot */
  .hero__chip--top          { top: 5%;     left: 50%;  transform: translateX(-50%); }
  .hero__chip--left-top     { top: 22%;    left: 2%;   }
  .hero__chip--left-mid     { top: 45%;    left: 0%;   }
  .hero__chip--left-bottom  { bottom: 20%; left: 4%;   }
  .hero__chip--right-bottom { bottom: 12%; right: 0%;  }

  /* Wave divider */
  .hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
    z-index: 2;
  }

  .hero__wave svg {
    display: block;
    width: 100%;
    height: 120px;
  }

  /* Scroll hint */
  .hero__scroll-hint {
    display: flex;
    justify-content: center;
    padding-top: var(--space-8);
    position: relative;
    z-index: 1;
  }

  .hero__scroll-arrow {
    opacity: 0.5;
    animation: scroll-bounce 1.8s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0);    opacity: 0.4; }
    50%       { transform: translateY(7px); opacity: 0.85; }
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      order: -1;
      height: clamp(300px, 60vw, 420px);
    }

    .hero__mascot {
      width: clamp(160px, 40vw, 260px);
    }
  }

  @media (max-width: 520px) {
    .hero {
      min-height: auto;
      padding-block: var(--space-10) var(--space-8);
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }

    .hero__scroll-hint {
      display: none;
    }
  }
</style>
