---
interface Props {
  posterSrc?: string;
  videoSrc?: string;
  embedUrl?: string;
}

const {
  posterSrc = "/assets/video-poster-placeholder.svg",
  videoSrc,
  embedUrl,
} = Astro.props;

const expectations = [
  "Wie digitale Risiken im Alltag wirklich aussehen",
  "Wie medienkundig Sie Schritt für Schritt begleitet",
  "Was Sie nach 10 Minuten Lernen bereits erkennen können",
];
---

<section class="section video-intro" id="video-intro" aria-labelledby="video-intro-heading">
  <div class="container video-intro__inner">

    <!-- Left: text -->
    <div class="video-intro__content">
      <span class="label-eyebrow">Schauen Sie selbst</span>
      <h2 id="video-intro-heading" class="video-intro__title">Verstehen in 90 Sekunden</h2>
      <p class="video-intro__desc">
        Ein kurzer Einstieg – damit Sie wissen, was Sie erwartet, bevor Sie starten.
      </p>

      <ul class="video-intro__expectations" role="list">
        {expectations.map((item) => (
          <li class="video-intro__expect-item">
            <span class="video-intro__check" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="8" fill="var(--color-primary-soft)"/>
                <polyline points="4.5,8 7,10.5 11.5,5.5" stroke="var(--color-primary)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>

      <p class="video-intro__inline-text">
        Sie starten mit einem kurzen Selbsttest, folgen dann interaktiven Lernpfaden
        zu den Themen die Sie interessieren – und können jederzeit pausieren,
        wiederholen und in Ihrem eigenen Tempo weitermachen.
      </p>
    </div>

    <!-- Right: video -->
    <div class="video-intro__player-wrap">
      <div class="video-intro__player">
        {embedUrl ? (
          <iframe
            src={embedUrl}
            title="Verstehen in 90 Sekunden – medienkundig Einführungsvideo"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="video-intro__iframe"
          ></iframe>
        ) : (
          <div class="video-intro__placeholder" id="video-placeholder">
            <!-- in-player badges -->
            <span class="video-intro__badge video-intro__badge--duration">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M6 3.5V6l2 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              90 Sek.
            </span>
            <span class="video-intro__badge video-intro__badge--subs">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <rect x="1" y="2.5" width="10" height="7" rx="1.2" stroke="currentColor" stroke-width="1.2"/>
                <rect x="2.5" y="5.5" width="2.5" height="1" rx="0.5" fill="currentColor"/>
                <rect x="6.5" y="5.5" width="3" height="1" rx="0.5" fill="currentColor"/>
                <rect x="2.5" y="7.2" width="4" height="1" rx="0.5" fill="currentColor"/>
              </svg>
              Untertitel
            </span>

            <img
              src={posterSrc}
              alt=""
              class="video-intro__poster"
              width="1280"
              height="720"
              loading="lazy"
            />
            <button
              class="video-intro__play"
              type="button"
              aria-label="Video abspielen: Verstehen in 90 Sekunden"
              id="play-btn"
            >
              <span class="video-intro__play-ring" aria-hidden="true"></span>
              <span class="video-intro__play-icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                  <path d="M10 7.5L21 14L10 20.5V7.5Z" fill="currentColor"/>
                </svg>
              </span>
            </button>
          </div>
        )}

        {videoSrc && (
          <video
            src={videoSrc}
            poster={posterSrc}
            controls
            preload="none"
            class="video-intro__video visually-hidden"
            id="video-el"
            aria-label="Verstehen in 90 Sekunden – medienkundig Einführungsvideo"
          >
            <track kind="captions" label="Deutsch" srclang="de" default />
            Ihr Browser unterstützt kein HTML-Video.
          </video>
        )}
      </div>
    </div>

  </div>
</section>

<style>
  .video-intro {
    position: relative;
    background-color: #ffffff;
    min-height: 85vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* subtle radial glow behind the video side */
  .video-intro::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 75% 50%, rgba(108, 63, 255, 0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  /* 2-column grid */
  .video-intro__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-16);
    align-items: center;
  }

  /* Left: content */
  .video-intro__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .video-intro__title {
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
  }

  .video-intro__desc {
    font-size: var(--text-md);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
  }

  /* Expectation bullets */
  .video-intro__expectations {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .video-intro__expect-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-soft);
    line-height: var(--leading-normal);
  }

  .video-intro__check {
    flex-shrink: 0;
    display: flex;
    margin-top: 2px;
  }

  .video-intro__inline-text {
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: var(--leading-relaxed);
    border-left: 3px solid var(--color-primary-soft);
    padding-left: var(--space-4);
  }

  /* Right: player wrapper */
  .video-intro__player-wrap {
    position: relative;
  }

  /* In-player overlay badges */
  .video-intro__badge {
    position: absolute;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 10px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .video-intro__badge--duration {
    top: var(--space-4);
    left: var(--space-4);
    background-color: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  .video-intro__badge--subs {
    top: var(--space-4);
    right: var(--space-4);
    background-color: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  /* Player */
  .video-intro__player {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: #12103a;
    box-shadow:
      0 0 0 1px rgba(108, 63, 255, 0.2),
      0 24px 64px rgba(108, 63, 255, 0.25),
      0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .video-intro__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-intro__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .video-intro__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: filter var(--transition-normal);
  }

  .video-intro__placeholder:hover .video-intro__poster {
    filter: brightness(0.8);
  }

  /* Play button */
  .video-intro__play {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    background: none;
    border: none;
    cursor: pointer;
    transition: transform var(--transition-normal);
  }

  .video-intro__play:hover {
    transform: scale(1.04);
  }

  /* Animated outer ring */
  .video-intro__play-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100px;
    height: 100px;
    transform: translate(-50%, calc(-50% - 22px));
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.3);
    animation: ring-pulse 2.2s ease-out infinite;
  }

  @keyframes ring-pulse {
    0%   { transform: translate(-50%, calc(-50% - 22px)) scale(0.85); opacity: 0.6; }
    70%  { transform: translate(-50%, calc(-50% - 22px)) scale(1.3);  opacity: 0; }
    100% { opacity: 0; }
  }

  .video-intro__play-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.95);
    color: var(--color-primary);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
    transition: background-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .video-intro__play:hover .video-intro__play-icon {
    background-color: #fff;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4);
  }

  .video-intro__play-label {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.95);
    letter-spacing: 0.02em;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
  }

  .video-intro__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 860px) {
    .video-intro {
      min-height: auto;
      padding-block: var(--space-16);
    }

    .video-intro__inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .video-intro__player-wrap {
      order: -1;
    }

    .video-intro__title {
      font-size: var(--text-3xl);
    }
  }

  @media (max-width: 480px) {
    .video-intro__duration-badge,
    .video-intro__subtitle-badge {
      font-size: 11px;
      padding: var(--space-1) var(--space-3);
    }
  }
</style>

<script>
  const placeholder = document.getElementById("video-placeholder");
  const videoEl = document.getElementById("video-el") as HTMLVideoElement | null;

  if (placeholder && videoEl) {
    document.getElementById("play-btn")?.addEventListener("click", () => {
      placeholder.classList.add("visually-hidden");
      videoEl.classList.remove("visually-hidden");
      videoEl.play();
    });
  }
</script>
