---
import "../styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Lightbox from "@/components/Lightbox.astro";
import GlossarModal from "@/components/GlossarModal.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = "medienkundig – Medienkompetenz für den digitalen Alltag",
  description = "medienkundig hilft Ihnen, digitale Risiken im Alltag besser einzuschätzen – Schritt für Schritt, verständlich und ohne Fachchinesisch.",
  canonicalUrl,
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6c3fff" />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Lightbox />
    <GlossarModal />
  </body>
</html>
